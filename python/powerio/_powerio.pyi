"""Type stubs for the compiled ``powerio._powerio`` extension (PyO3).

Hand-written to match powerio-py/src/lib.rs. Keep in sync when the Rust ABI
changes; this is what makes the ``py.typed`` package statically checkable. The
matrix methods return COO triplets as plain Python lists; the pure-Python
``powerio.Network`` wrapper turns them into scipy/networkx objects.
"""

from typing import Any, Optional, Tuple

__version__: str
_has_gridfm: bool

class PowerIOError(Exception):
    """Base error from the powerio parser, converter, or matrix builders."""

class PowerIOParseError(PowerIOError):
    """A case file is malformed or unparseable."""

class PowerIODataError(PowerIOError):
    """A well-formed case cannot satisfy a requested operation."""

class PyCase:
    @property
    def name(self) -> str: ...
    @property
    def base_mva(self) -> float: ...
    @property
    def source_format(
        self,
    ) -> Literal[
        "Matpower", "PowerModelsJson", "EgretJson", "Psse", "PowerWorld", "InMemory", "Normalized"
    ]: ...
    @property
    def n_buses(self) -> int: ...
    @property
    def n_branches(self) -> int: ...
    @property
    def n_gens(self) -> int: ...
    @property
    def n_loads(self) -> int: ...
    @property
    def n_shunts(self) -> int: ...
    @property
    def is_radial(self) -> bool: ...
    @property
    def n_connected_components(self) -> int: ...
    @property
    def buses(self) -> list[dict]: ...
    @property
    def loads(self) -> list[dict]: ...
    @property
    def shunts(self) -> list[dict]: ...
    @property
    def branches(self) -> list[dict]: ...
    @property
    def generators(self) -> list[dict]: ...
    def reference_bus_index(self) -> int: ...
    def reference_bus_indices(self) -> list[int]: ...
    def connectivity_report(self) -> dict: ...
    def to_matpower(self) -> str: ...
    def to_json(self) -> str: ...
    def to_format(self, to: str) -> Tuple[str, list[str]]: ...
    def to_normalized(self) -> PyCase: ...
    # Matrix builders return COO triplets `(data, row, col, (nrows, ncols))` as
    # plain Python lists, except `incidence`/`ybus_parts` which nest them.
    def bprime(self, scheme: Optional[str] = ...) -> Any: ...
    def bdoubleprime(self, scheme: Optional[str] = ...) -> Any: ...
    def lacpf(self, include_taps: bool = ..., include_shifts: bool = ...) -> Any: ...
    def adjacency(self) -> Any: ...
    def ybus_parts(
        self, include_taps: bool = ..., include_shifts: bool = ...
    ) -> Any: ...
    def ptdf(self, convention: Optional[str] = ...) -> Any: ...
    def lodf(self, convention: Optional[str] = ...) -> Any: ...
    def weighted_laplacian(self, convention: Optional[str] = ...) -> Any: ...
    def incidence(self, convention: Optional[str] = ...) -> Any: ...
    def write_dcopf_bundle(
        self, out_dir: str, convention: Optional[str] = ..., units: Optional[str] = ...
    ) -> dict: ...
    # Only present when the extension was compiled with the `gridfm` cargo
    # feature (the released wheel is); without it, access raises AttributeError.
    def write_gridfm(
        self,
        out_dir: str,
        scenario: int = ...,
        include_y_bus: bool = ...,
        include_taps: bool = ...,
        include_shifts: bool = ...,
    ) -> dict: ...
    def __repr__(self) -> str: ...

def parse_file(path: str, from_: Optional[str] = ...) -> PyCase: ...
def parse_str(text: str, format: Optional[str] = ...) -> PyCase: ...
def from_json(text: str) -> PyCase: ...
def convert_file(
    path: str, to: str, from_: Optional[str] = ...
) -> Tuple[str, list[str]]: ...
def convert_str(
    text: str, to: str, format: Optional[str] = ...
) -> Tuple[str, list[str]]: ...
def generate_case(
    topology: Optional[str] = ...,
    n: int = ...,
    r_over_x: float = ...,
    mean_x: float = ...,
    seed: int = ...,
) -> PyCase: ...
# Only present when the extension was compiled with the `gridfm` cargo feature
# (the released wheel is); without it, access raises AttributeError.
def write_gridfm_batch(
    cases: list[PyCase],
    out_dir: str,
    base_scenario: int = ...,
    include_y_bus: bool = ...,
    include_taps: bool = ...,
    include_shifts: bool = ...,
) -> dict: ...
def read_gridfm(dir: str, scenario: int = ...) -> Tuple[PyCase, int, list[str]]: ...
def read_gridfm_scenarios(dir: str) -> list[Tuple[PyCase, int, list[str]]]: ...
